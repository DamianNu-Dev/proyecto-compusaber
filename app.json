{
  "expo": {
    "name": "Compusaber",
    "slug": "compusaber",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo1.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo1.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo1.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.compusaber.app"
    },
    "web": {
      "favicon": "./assets/logo1.png",
      "bundler": "metro",
      "output": "static",
      "backgroundColor": "#0F172A",
      "display": "standalone"
    },
    "extra": {
      "eas": {
        "projectId": "2735cf90-acc0-4ea7-8414-0329f289f94e"
      }
    }
  }
}
